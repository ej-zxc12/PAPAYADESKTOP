rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Allow read/write access for development (remove this in production)
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Specific rules for collections
    match /grades/{gradeId} {
      allow read, write: if true;
    }
    
    match /students/{studentId} {
      allow read, write: if true;
    }
    
    match /subjects/{subjectId} {
      allow read, write: if true;
    }
    
    match /teachers/{teacherId} {
      allow read, write: if true;
    }
    
    // Website can read, only admin can write
    match /orgChartMembers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
 
    match /orgChartMeta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Calendar events: users manage their own events.
    match /users/{uid}/events/{eventId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }
    
    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /alumni/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missionVision/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appleScholarship/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /pineappleProject/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
